---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import TerminalShell from '../components/Terminal/TerminalShell.astro';
---

<Layout>
  <!-- Theme toggle in header -->
  <ThemeToggle slot="header-actions" />

  <section class="hero" aria-label="Terminal hero">
    <h1 class="hero-heading sr-only">primetimetank21 — Interactive Portfolio Terminal</h1>
    <TerminalShell />
  </section>

  <!--
    M2 content slots — structural scaffolding only.
    Real content (about, projects, links) goes here in M2.
  -->
</Layout>

<style>
  .hero {
    width: 100%;
    max-width: var(--terminal-max-width);
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }

  /* Visually hidden but accessible to screen readers */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
